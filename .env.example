# DocVerify environment overrides.
# Copy to `.env` (gitignored) and set real values before any non-local use.

# Postgres password used by both the `db` service and the backend's
# DATABASE_URL. Defaults to `docverify_pass` for local dev if unset — ROTATE
# this before deploying anywhere reachable.
POSTGRES_PASSWORD=docverify_pass

# On-chain ledger (L7) contract address. Usually left unset: the `ledger`
# container deploys DocRegistry on startup and writes its address to a
# shared volume the backend reads automatically. Only set this to point the
# backend at a pre-deployed contract on a non-local network.
LEDGER_CONTRACT_ADDRESS=
