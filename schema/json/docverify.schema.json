    "BoundingBox": {
      "description": "A rectangle over a document page.\n\n``units`` distinguishes UI coordinates (``pct`` \u2014 0..100 of page width/height,\nwhat the Document Viewer renders) from raw forensic pixels (``px``).",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "w": {
          "type": "number"
        },
        "h": {
          "type": "number"
        },
        "units": {
          "default": "pct",
          "type": "string"
        }
      },
      "required": [
        "x",
        "y",
        "w",
        "h",
        "units"
      ],
      "title": "BoundingBox",
      "type": "object"
    },
    "Case": {
      "description": "The full case record \u2014 the primary read model for the frontend.\n\nDeliberately flat: applicant/loan context, the analysis projection and the\ndecision live side by side so the dashboard and report screens read one\nobject. Structured creation input uses :class:`Applicant` / :class:`Loan`.",
      "properties": {
        "id": {
          "type": "string"
        },
        "applicant": {
          "type": "string"
        },
        "pan": {
          "default": "",
          "type": "string"
        },
        "loanType": {
          "default": "",
          "type": "string"
        },
        "loanAmount": {
          "default": 0,
          "type": "number"
