  "$defs": {
    "Anomaly": {
      "description": "A single detected anomaly.\n\n``code`` is the stable machine identifier the ML/registry layers emit;\n``layer`` is which engine found it (provenance); ``category`` is how it is\ngrouped for the underwriter (derive both from :mod:`schema.enums`).",
      "properties": {
        "id": {
          "type": "string"
        },
        "code": {
          "default": "",
          "type": "string"
        },
        "layer": {
          "$ref": "#/$defs/AnomalyLayer"
        },
        "category": {
          "$ref": "#/$defs/AnomalyCategory"
        },
        "severity": {
          "$ref": "#/$defs/RiskBand"
        },
        "title": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "documentIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "evidence": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "required": [
        "id",
        "code",
        "layer",
        "category",
        "severity",
        "title",
        "detail",
        "documentIds",
        "evidence"
      ],
      "title": "Anomaly",
      "type": "object"
    },
    "AnomalyCategory": {
      "description": "How a finding is grouped for the underwriter (display-facing).",
      "enum": [
        "Tamper Detection",
        "Cross-Document Conflict",
        "Metadata Anomaly",
        "Registry Mismatch"
      ],
      "title": "AnomalyCategory",
      "type": "string"
    },
    "AnomalyLayer": {
      "description": "Which detection layer/engine produced a finding (provenance, ML-facing).",
      "enum": [
        "ingestion",
        "tamper",
        "cross_document",
        "registry"
      ],
      "title": "AnomalyLayer",
      "type": "string"
    },
    "AnomalyRegion": {
      "description": "A flagged region drawn on a document page and linked to a finding.",
      "properties": {
        "id": {
          "type": "string"
        },
        "docId": {
          "default": "",
          "type": "string"
        },
        "page": {
          "default": 1,
          "type": "integer"
        },
        "label": {
          "default": "",
          "type": "string"
        },
        "box": {
          "$ref": "#/$defs/BoundingBox"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
