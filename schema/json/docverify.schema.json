      },
      "required": [
        "id",
        "docId",
        "page",
        "label",
        "box",
        "source"
      ],
      "title": "AnomalyRegion",
      "type": "object"
    },
    "Applicant": {
      "description": "Applicant details captured at case creation (Screen 3).",
