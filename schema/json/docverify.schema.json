    "AuditEntry": {
      "description": "One tamper-evident ledger record (hash-chained). The blockchain area owns\nthis shape; the chain is computed over the snake_case JSON in app/audit.py.",
      "properties": {
        "caseId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "documentHashes": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "fraudScore": {
          "type": "integer"
        },
        "riskBand": {
          "$ref": "#/$defs/RiskBand"
